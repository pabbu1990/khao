# Supabase — get these from your Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public base URL of the app (used for building storefront links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Stripe (only needed for the online-payment path — M4)
# STRIPE_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Contact form (Resend) — M-contact
RESEND_API_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CONTACT_EMAIL=your-email@gmail.com
# Optional: defaults to "Khao <onboarding@resend.dev>" (Resend test sender)
# CONTACT_FROM=Khao <hello@yourdomain.com>
